{{ form_start(form, {
	'attr': {'class': 'needs-validation', 'novalidate': 'novalidate', 'id': 'ticket-form'}
}) }}

<div class="row">
	<div class="col-md-6 mb-3">
		{{ form_label(form.title, 'Titre', {'label_attr': {'class': 'form-label fw-bold'}}) }}
		{{ form_widget(form.title, {'attr': {'class': 'form-control', 'placeholder': 'Titre du ticket'}}) }}
		{{ form_errors(form.title) }}
	</div>
	<div class="col-md-6 mb-3">
		{{ form_label(form.marchand, 'Marchand', {'label_attr': {'class': 'form-label'}}) }}
		{{ form_widget(form.marchand, {'attr': {'class': 'form-control', 'placeholder': 'Nom du marchand'}}) }}
		{{ form_errors(form.marchand) }}
	</div>
</div>

<div class="row">
	<div class="col-12 mb-3">
		{{ form_label(form.description, 'Description', {'label_attr': {'class': 'form-label'}}) }}
		{{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 3, 'placeholder': 'Description du problème'}}) }}
		{{ form_errors(form.description) }}
	</div>
</div>

<div class="d-flex justify-content-between align-items-center">
	<a href="{{ path('app_ticket_index') }}" class="btn btn-outline-secondary">
		<i class="bi bi-arrow-left"></i>
		Retour
	</a>
	<button type="submit" class="btn btn-primary px-5 shadow-sm">
		<i class="bi bi-check-circle me-2"></i>
		{{ button_label|default('Enregistrer') }}
	</button>
</div>

{{ form_end(form) }}
