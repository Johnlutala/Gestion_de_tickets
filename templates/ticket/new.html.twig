{% extends 'base.html.twig' %}

{% block title %}New Ticket{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="card shadow-sm rounded-3 d-flex flex-column" style="max-height: 70vh;">
        {# === Zone écriture / formulaire === #}
        <div class="container-fluid bg-white p-3" style="max-width: 1200px;">

            {{ form_start(form) }}

            {# Ligne Titre + Nom du marchand #}
            <div class="row mb-2">
                <div class="col-md-6 mb-2 mb-md-0">
                    {{ form_widget(form.title, {'attr': {'class': 'form-control', 'placeholder': 'Titre du ticket'}}) }}
                </div>
                <div class="col-md-6">
                    {{ form_widget(form.marchand, {'attr': {'class': 'form-control', 'placeholder': 'Nom du marchand'}}) }}
                </div>
            </div>

            {# Zone corps du message + bouton envoyer #}
            <div class="d-flex gap-2 align-items-start">
                {{ form_widget(form.description, {'attr': {'class': 'form-control flex-grow-1', 'placeholder': 'Écrire un message...', 'style': 'min-height: 80px; padding: 10px;'}}) }}

                <button type="submit" class="btn btn-primary d-flex align-items-center justify-content-center" style="width: 50px; height: 50px; border-radius: 50%;">
                    <i class="bi bi-send"></i>
                </button>
            </div>

            {{ form_end(form) }}
        </div>
    </div>
</div>

{# Scroll automatique en bas #}
<script>
    const chat = document.getElementById('chat-messages');
    if (chat) {
        chat.scrollTop = chat.scrollHeight;
    }
</script>
{% endblock %}