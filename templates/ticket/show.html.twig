{% extends 'base.html.twig' %}

{% block title %}Ticket{% endblock %}

{% block body %}
    <h1>Ticket</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ ticket.id }}</td>
            </tr>
            <tr>
                <th>Title</th>
                <td>{{ ticket.title }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ ticket.description }}</td>
            </tr>
            <tr>
                <th>Marchand</th>
                <td>{{ ticket.marchand }}</td>
            </tr>
            <tr>
                <th>Note</th>
                <td>{{ ticket.note }}</td>
            </tr>
            <tr>
                <th>Noted</th>
                <td>{{ ticket.noted ? 'Yes' : 'No' }}</td>
            </tr>
            <tr>
                <th>Comment</th>
                <td>{{ ticket.comment }}</td>
            </tr>
            <tr>
                <th>Enabled</th>
                <td>{{ ticket.enabled ? 'Yes' : 'No' }}</td>
            </tr>
            <tr>
                <th>Deleted</th>
                <td>{{ ticket.deleted ? 'Yes' : 'No' }}</td>
            </tr>
            <tr>
                <th>Year</th>
                <td>{{ ticket.year }}</td>
            </tr>
            <tr>
                <th>Month</th>
                <td>{{ ticket.month }}</td>
            </tr>
            <tr>
                <th>Quarter</th>
                <td>{{ ticket.quarter }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_ticket_index') }}">back to list</a>

    <a href="{{ path('app_ticket_edit', {'id': ticket.id}) }}">edit</a>

    {{ include('ticket/_delete_form.html.twig') }}
{% endblock %}
