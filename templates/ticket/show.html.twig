{% extends 'base.html.twig' %}

{% block title %}
	-Détails Ticket
{% endblock %}

{% block body %}
	<div class="container py-4" style="margin-right: 20px;">
		<div class="table-responsive">
			<div class="card shadow-sm border-0">
				<div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
					<h5 class="mb-0">
						<i class="bi bi-chat-dots me-2"></i>
						Ticket #{{ ticket.id }}
						-
						{{ ticket.title }}
					</h5>

					<a href="{{ path('app_ticket_index') }}" class="btn btn-light btn-sm">
						<i class="bi bi-arrow-left me-1"></i>Retour
					</a>
				</div>

				<div class="card-body">
					<table class="table table-bordered align-middle">
						<tbody>
							<tr>
								<th class="bg-light" style="width:30%">
									<i class="bi bi-hash text-primary me-2"></i>ID
								</th>
								<td>{{ ticket.id }}</td>
							</tr>

							<tr>
								<th class="bg-light">
									<i class="bi bi-card-text text-primary me-2"></i>Titre
								</th>
								<td class="fw-semibold">{{ ticket.title }}</td>
							</tr>

							<tr>
								<th class="bg-light">
									<i class="bi bi-file-text text-primary me-2"></i>Description
								</th>
								<td>{{ ticket.description }}</td>
							</tr>

							<tr>
								<th class="bg-light">
									<i class="bi bi-person-badge text-primary me-2"></i>Marchand
								</th>
								<td>{{ ticket.marchand }}</td>
							</tr>

							<tr>
								<th class="bg-light">
									<i class="bi bi-star text-primary me-2"></i>Note
								</th>
								<td>
									<span class="badge bg-info">{{ ticket.note }}</span>
								</td>
							</tr>

							<tr>
								<th class="bg-light">
									<i class="bi bi-check-circle text-primary me-2"></i>Noté
								</th>
								<td>
									{% if ticket.noted %}
										<span class="badge bg-success">Oui</span>
									{% else %}
										<span class="badge bg-secondary">Non</span>
									{% endif %}
								</td>
							</tr>

							<tr>
								<th class="bg-light">
									<i class="bi bi-chat-left-text text-primary me-2"></i>Commentaire
								</th>
								<td>{{ ticket.comment|default('—') }}</td>
							</tr>

							<tr>
								<th class="bg-light">
									<i class="bi bi-toggle-on text-primary me-2"></i>Activé
								</th>
								<td>
									{% if ticket.enabled %}
										<span class="badge bg-success">Oui</span>
									{% else %}
										<span class="badge bg-danger">Non</span>
									{% endif %}
								</td>
							</tr>

							<tr>
								<th class="bg-light">
									<i class="bi bi-trash text-primary me-2"></i>Supprimé
								</th>
								<td>
									{% if ticket.deleted %}
										<span class="badge bg-danger">Oui</span>
									{% else %}
										<span class="badge bg-success">Non</span>
									{% endif %}
								</td>
							</tr>
						
						</tbody>
					</table>

					<div class="d-flex justify-content-between mt-3">
						<div>
                        	{% if is_granted('ROLE_ADMIN') or is_granted('ROLE_MARCHAND') %}
							<a href="{{ path('app_ticket_edit', {'id': ticket.id}) }}" class="btn btn-primary btn-sm me-2">
								<i class="bi bi-pencil me-1"></i>Modifier
                                {% endif %}
							</a>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
{% endblock %}
