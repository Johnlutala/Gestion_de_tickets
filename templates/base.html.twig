				// remove theme submit blocker as soon as jQuery is ready
if (window.jQuery) {
$(function () {
$('#user-form').off('submit');
$('#privilege-form').off('submit');
$('#role-form').off('submit');
$('#application-form').off('submit');
$('#ticket-form').off('submit');
$('#replyForm').off('submit');
$('#new-ticket-form').off('submit');
$('#edit-ticket-form').off('submit');
$('#delete-ticket-form').off('submit');
});
}

// Defensive: remove duplicate bootstrap-select wrappers to avoid double-rendered buttons
if (window.jQuery) {
	(function($){
		$(function(){
			$('.form-selects').each(function(){
				var $select = $(this);
				var $wrappers = $select.parents('.bootstrap-select');
				if ($wrappers.length > 1) {
					var $first = $($wrappers.get(0));
					// ensure the select is a child of the first wrapper
					if ($first.find($select).length === 0) {
						$first.append($select);
					}
					// remove extra wrappers
					$wrappers.slice(1).remove();
				}
			});
		});
	})(jQuery);
}
			</script>
