{% extends 'base.html.twig' %}

{% block title %}Liste des applications{% endblock %}

{% block body %}

	<div class="container">

		<div class="card mb-4">

			<div class="card-body">

				<div class="d-flex justify-content-between align-items-center mb-3">

					<div>
						<h4 class="fw-bold mb-0">
							<i class="bi bi-app text-primary me-2"></i>
							Liste des applications
						</h4>
						<small class="text-muted">Gestion des applications et clés API</small>
					</div>

					<a href="{{ path('app_application_new') }}" class="btn btn-primary btn-sm">
						<i class="bi bi-plus-circle me-1"></i>
						Nouvelle application
					</a>

				</div>

				{% if applications|length > 0 %}
					<div class="table-responsive">
						<table class="table table-hover align-middle">

							<thead class="table-light">
								<tr>
									<th>#</th>
									<th>Nom de l'application</th>
									<th>Clé API</th>
									<th>Clé secrète</th>
									<th class="text-end">Actions</th>
								</tr>
							</thead>

							<tbody>
								{% for application in applications %}
									<tr>
										<td>{{ loop.index }}</td>
										<td>
											<div class="fw-semibold">
												<span class="badge bg-info">{{ application.name }}</span>
											</div>
										</td>
										<td>
											<code class="text-muted small">{{ application.keyId|slice(0, 8) }}...</code>
											<button class="btn btn-sm btn-outline-secondary ms-1" onclick="copyToClipboard('{{ application.keyId }}')" title="Copier">
												<i class="bi bi-clipboard"></i>
											</button>
										</td>
										<td>
											<code class="text-muted small">{{ application.secretKey|slice(0, 8) }}...</code>
											<button class="btn btn-sm btn-outline-secondary ms-1" onclick="copyToClipboard('{{ application.secretKey }}')" title="Copier">
												<i class="bi bi-clipboard"></i>
											</button>
										</td>
										<td class="text-end">
											<div class="btn-group" role="group">
												<a href="{{ path('app_application_show', {'id': application.id}) }}" class="btn btn-sm btn-outline-info" title="Voir">
													<i class="bi bi-eye"></i>
												</a>
												<a href="{{ path('app_application_edit', {'id': application.id}) }}" class="btn btn-sm btn-outline-warning" title="Modifier">
													<i class="bi bi-pencil"></i>
												</a>
												<form method="post" action="{{ path('app_application_delete', {'id': application.id}) }}" class="d-inline" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette application ?');">
													<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ application.id) }}">
													<button class="btn btn-sm btn-outline-danger" title="Supprimer">
														<i class="bi bi-trash"></i>
													</button>
												</form>
											</div>
										</td>
									</tr>
								{% endfor %}
							</tbody>
						</table>
					</div>
				{% else %}
					<div class="text-center py-5">
						<i class="bi bi-app display-1 text-muted mb-3"></i>
						<h5 class="text-muted">Aucune application trouvée</h5>
						<p class="text-muted mb-4">Commencez par créer votre première application.</p>
						<a href="{{ path('app_application_new') }}" class="btn btn-primary">
							<i class="bi bi-plus-circle me-2"></i>Créer la première application
						</a>
					</div>
				{% endif %}
			</div>
		</div>
	</div>

	<script>
	function copyToClipboard(text) {
		navigator.clipboard.writeText(text).then(function() {
			showNotification('Copié dans le presse-papiers !', 'success');
		}, function(err) {
			console.error('Erreur lors de la copie: ', err);
			showNotification('Erreur lors de la copie', 'error');
		});
	}

	function showNotification(message, type) {
		const notification = document.createElement('div');
		notification.className = `alert alert-${type === 'success' ? 'success' : 'danger'} alert-dismissible fade show position-fixed`;
		notification.style.cssText = 'top: 20px; right: 20px; z-index: 9999; min-width: 300px;';
		notification.innerHTML = `
			${message}
			<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
		`;
		document.body.appendChild(notification);

		setTimeout(() => {
			notification.remove();
		}, 3000);
	}
	</script>

{% endblock %}
