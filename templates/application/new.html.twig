{% extends 'base.html.twig' %}

{% block title %}Nouvelle application{% endblock %}

{% block body %}

	<div class="container">

		<div class="card mb-4">

			<div class="card-body">

				<div class="d-flex justify-content-between align-items-center mb-3">

					<div>
						<h4 class="fw-bold mb-0">
							<i class="bi bi-plus-circle text-primary me-2"></i>
							Nouvelle application
						</h4>
						<small class="text-muted">Créer une nouvelle application avec des clés API</small>
					</div>

					<a href="{{ path('app_application_index') }}" class="btn btn-outline-secondary btn-sm">
						<i class="bi bi-arrow-left me-1"></i>Retour
					</a>

				</div>

				<div class="alert alert-info">
					<i class="bi bi-info-circle me-2"></i>
					<strong>Information :</strong> Renseignez les clés d'API fournies par votre application.
				</div>

				{{ include('application/_form.html.twig') }}

			</div>
		</div>
	</div>

{% endblock %}
