{{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}

    <div class="row">
        <div class="col-12">
            <div class="mb-3">
                {{ form_label(form.name, "Nom de l'application", {'label_attr': {'class': 'form-label fw-bold'}}) }}
                {{ form_widget(form.name, {'attr': {'class': 'form-control', 'placeholder': 'Ex: Application Mobile, API Web, etc.'}}) }}
                {{ form_errors(form.name) }}
                <div class="form-text">
                    <i class="bi bi-info-circle me-1"></i>Choisissez un nom descriptif pour votre application.
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="mb-3">
                {{ form_label(form.key_id, "Clé d'API", {'label_attr': {'class': 'form-label fw-bold'}}) }}
                {{ form_widget(form.key_id, {'attr': {'class': 'form-control font-monospace', 'placeholder': 'Entrez la clé d\'API'}}) }}
                {{ form_errors(form.key_id) }}
                <div class="form-text">
                    <i class="bi bi-shield me-1"></i>Clé unique pour identifier votre application.
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="mb-3">
                {{ form_label(form.secret_key, "Clé Secrète", {'label_attr': {'class': 'form-label fw-bold'}}) }}
                {{ form_widget(form.secret_key, {'attr': {'class': 'form-control font-monospace', 'placeholder': 'Entrez la clé secrète'}}) }}
                {{ form_errors(form.secret_key) }}
                <div class="form-text">
                    <i class="bi bi-exclamation-triangle text-warning me-1"></i>Conservez cette clé en sécurité !
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-end gap-2 mt-4">
                {# <a href="{{ path('app_application_index') }}" class="btn btn-outline-secondary">
                    <i class="bi bi-x-circle me-1"></i>Annuler
                </a> #}
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-circle me-2"></i>{{ button_label|default('Enregistrer') }}
                </button>
            </div>
        </div>
    </div>

{{ form_end(form) }}

