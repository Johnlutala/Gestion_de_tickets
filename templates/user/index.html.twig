{% extends 'base.html.twig' %}

{% block title %}Liste des utilisateurs
{% endblock %}

{% block body %}

	<div class="container" style="margin-right: 20px;">
		<div class="card mb-4">

			<div class="card-body">

				<div class="d-flex justify-content-between align-items-center mb-3">

					<div>
						<h4 class="fw-bold mb-0">
							<i class="bi bi-people text-primary me-2"></i>
							Liste des utilisateurs
						</h4>
						<small class="text-muted">Gestion des comptes utilisateurs</small>
					</div>

					<a href="{{ path('app_user_new') }}" class="btn btn-primary btn-sm">
						<i class="bi bi-plus-circle me-1"></i>
						Nouveau
					</a>

				</div>

				<div class="table-responsive">
					<table class="table table-hover align-middle">

						<thead class="table-light">
							<tr>
								<th>#</th>
								<th>Noms</th>
								<th>Nom d'utilisateur</th>
								<th>Application</th>
								<th>Profile</th>
								<th>Privilèges</th>
								<th class="text-end">Actions</th>
							</tr>
						</thead>

						{% for user in users %}

							<tr>

								<td>{{ loop.index }}</td>
								<td>{{ user.prenom|default('') }}
									{{ user.nom|default('') }}</td>
								<td>
									<div class="fw-semibold">
										{{ user.username }}
									</div>
								</td>
								<td>{{ user.application ? user.application.name|default('no defined') : 'no defined' }}</td>
								<td>
									{% if user.profile %}
										<span class="badge bg-primary text-white" style="font-size: 0.7rem; padding: 0.5rem 0.75rem;">
											<i class="bi bi-shield-lock me-1"></i>
											{{ user.profile.nom }}
										</span>
									{% else %}
										<span class="text-muted small">
											<i class="bi bi-dash-circle me-1"></i>
											Aucun profil</span>
									{% endif %}
								</td>
								<td>
									{% if user.profile %}
										{% set privileges = user.profile.privileges %}
										{% if privileges|length > 0 %}
											<div class="d-flex flex-wrap gap-1">
												{% for privilege in privileges %}
													<span class="badge bg-success text-white" style="font-size: 0.6rem; padding: 0.4rem 0.6rem;">
														<i class="bi bi-check-circle me-1"></i>
														{{ privilege.name }}
													</span>
												{% endfor %}
											</div>
										{% else %}
											<span class="text-muted small">
												<i class="bi bi-dash-circle me-1"></i>Aucun privilège</span>
										{% endif %}
									{% else %}
										<span class="text-muted small">—</span>
									{% endif %}
								</td>
								<td>
									<div class="d-flex justify-content-end">
										<div class="dropdown">
											<button type="button" class="btn p-0 dropdown-toggle" data-bs-toggle="dropdown">
												<i class="bx bx-dots-vertical-rounded"></i>
											</button>

											<div class="dropdown-menu">
												<a href="{{ path('app_user_show', {'id': user.id}) }}" class="dropdown-item">

													<i class="ti ti-eye me-1"></i>
													Voir

												</a>

												<a href="{{ path('app_user_edit', {'id': user.id}) }}" class="dropdown-item">

													<i class="ti ti-pencil me-1"></i>
													Modifier

												</a>
												<form id="delete-user-{{ user.id }}" method="post" action="{{ path('app_user_delete', {'id': user.id}) }}" class="d-none">
													<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
												</form>
												<a href="#" class="dropdown-item text-danger" onclick="event.preventDefault(); if (confirm('Voulez-vous vraiment supprimer cet utilisateur ?')) { document.getElementById('delete-user-{{ user.id }}').submit(); }">
													<i class="ti ti-trash me-1"></i>Supprimer
												</a>
											</div>
										</div>
									</div>
								</td>
							</tr>

						{% else %}

							<tr>
								<td colspan="4" class="text-center text-muted py-4">
									<i class="bi bi-people fs-3 d-block mb-2"></i>
									Aucun utilisateur trouvé.

								</td>

							</tr>

						{% endfor %}

					</tbody>

				</table>

			</div>

		</div>

	</div>

</div>{% endblock %}
