{% extends 'base.html.twig' %}

{% block title %} - Liste des utilisateurs {% endblock %}

{% block body %}

	<div class="container">
     <div class="card mb-4">
    <div class="card-body mb-3">
				<h4 class="card-title">Liste des utilisateurs</h4>
				<a href="{{ path('app_user_new') }}" class="btn btn-primary float-end">
					<i class="bi bi-plus-circle"></i>
					Nouveau
				</a>


				<div class="table-responsive">
					<table class="table table-hover align-middle">
						<thead class="table-light">
							<tr>
								<th>#</th>
								<th>Nom d'utilisateur</th>
								<th>Rôles</th>
								<th class="text-end">Actions</th>
							</tr>
						</thead>
						<tbody>
							{% for user in users %}
								<tr>
									<td>{{ loop.index }}</td>
									<td>
										<div class="fw-semibold">{{ user.username }}</div>
									</td>
									<td>
										{% for role in user.roles %}
											{% if role == 'ROLE_ADMIN' %}
												<span class="badge bg-danger me-1">Administrateur</span>
											{% elseif role == 'ROLE_USER' %}
												<span class="badge bg-primary me-1">Utilisateur</span>
											{% else %}
												<span class="badge bg-light text-dark me-1">{{ role }}</span>
											{% endif %}
										{% endfor %}
									</td>
									<td>
										<div class="d-flex justify-content-end">
												<div class="dropdown">
													<button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
														<i class="bx bx-dots-vertical-rounded"></i>
													</button>
													<div class="dropdown-menu">
														<a href="{{ path('app_user_show', {'id': user.id}) }}" class="dropdown-item">
															<i class="ti ti-eye me-1"></i>Voir
														</a>
														<a href="{{ path('app_user_edit', {'id': user.id}) }}" class="dropdown-item">
															<i class="ti ti-pencil me-1"></i>Modifier
														</a>
														<form method="post" action="{{ path('app_user_delete', {'id': user.id}) }}" onsubmit="return confirm('Voulez-vous vraiment supprimer cet utilisateur ?');">
															<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
															<button type="submit" class="dropdown-item text-danger">
																<i class="ti ti-trash me-1"></i>Supprimer
															</button>
														</form>
													</div>
												</div>
										</div>
									</td>
								</tr>
							{% else %}
								<tr>
									<td colspan="7" class="text-center text-muted py-4">
										{% if app.request.get('q') or app.request.get('role') %}
											<i class="bi bi-search text-muted fs-3 d-block mb-2"></i>
											<strong>Aucun résultat trouvé</strong>
											<p class="mb-0">Essayez de modifier vos critères de recherche</p>
										{% else %}
											<i class="bi bi-people text-muted fs-3 d-block mb-2"></i>
											Aucun utilisateur trouvé.
										{% endif %}
									</td>
								</tr>
							{% endfor %}
						</tbody>
					</table>
				</div>


			</div>
		</div>

	{% endblock %}
