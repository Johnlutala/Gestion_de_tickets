{% extends 'base.html.twig' %}

{% block title %}- Tous utilisateurs
{% endblock %}

{% block body %}

	<div class="container" style="margin-right: 20px;">
		<div class="card mb-0">
			<div class="card-body">
				<div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-start mb-3">
					<div class="mb-3 mb-lg-0">
						<h4 class="fw-bold mb-1">
							<i class="bi bi-people text-primary me-2"></i>
							Liste des utilisateurs
						</h4>
						<small class="text-muted">Gestion des comptes utilisateurs</small>
					</div>

					<div class="d-flex align-items-center gap-2">
						<a href="{{ path('app_user_new') }}" class="btn btn-primary btn-sm">
							<i class="bi bi-plus-circle me-1"></i>
							Nouveau
						</a>
					</div>

				</div>

				<form method="get" id="user-filter-form" class="row g-2 mt-3">
					<input type="hidden" name="q" value="{{ searchQuery|default('') }}">
					<div class="col-sm-6 col-lg-4">
						<label class="form-label text-uppercase small text-muted mb-1">Application</label>
						<select name="application" id="user-application-select" class="form-select form-select-sm" onchange="this.form.submit()">
							<option value="">Toutes les applications</option>
							{% for application in applications %}
								<option value="{{ application.id }}" {{ selectedApplication == application.id ? 'selected' : '' }}>{{ application.name }}</option>
							{% endfor %}
						</select>
					</div>
					<div class="col-sm-6 col-lg-4">
						<label class="form-label text-uppercase small text-muted mb-1">Marchand</label>
						<select name="marchand" id="user-marchand-select" class="form-select form-select-sm" onchange="this.form.submit()">
							<option value="">Tous les marchands</option>
							{% for marchand in marchands %}
								<option value="{{ marchand.id }}" {{ selectedMarchand == marchand.id ? 'selected' : '' }}>{{ marchand.username }}</option>
							{% endfor %}
						</select>
					</div>
					<div class="col-sm-6 col-lg-2 align-self-end">
						<button type="submit" class="btn btn-outline-primary btn-sm w-100">
							<i class="bi bi-filter me-1"></i>Filtrer
						</button>
					</div>
				</form>

				<div class="row g-2 mt-3">
					<div class="col-auto">
						<span class="badge bg-primary fs-6">
							<i class="bi bi-people me-1"></i>Total:
							{{ users|length }}
						</span>
					</div>
					{% if selectedApplicationLabel %}
						<div class="col-auto">
							<span class="badge bg-info text-dark">
								<i class="bi bi-grid me-1"></i>
								{{ selectedApplicationLabel }}
							</span>
						</div>
					{% endif %}
					{% if selectedMarchandLabel %}
						<div class="col-auto">
							<span class="badge bg-success">
								<i class="bi bi-person-badge me-1"></i>
								{{ selectedMarchandLabel }}
							</span>
						</div>
					{% endif %}
					{% if searchQuery %}
						<div class="col-auto">
							<span class="badge text-white" style="background-color: #6f42c1;">
								<i class="bi bi-search me-1"></i>
								{{ searchQuery }}
							</span>
						</div>
					{% endif %}
					{% if selectedApplication or selectedMarchand or searchQuery %}
						<div class="col-auto">
							<a href="{{ path('app_user_index') }}" class="badge bg-danger text-decoration-none">
								<i class="bi bi-arrow-repeat me-0"></i>
							</a>
						</div>
					{% endif %}
				</div>

				<div class="table-responsive">
					<table class="table table-hover align-middle">

						<thead class="table-light">
							<tr>
								<th>#</th>
								<th>Noms</th>
								<th>Nom d'utilisateur</th>
								<th>Application</th>
								<th>Profile</th>
								<th>Privilèges</th>
								<th class="text-end">Actions</th>
							</tr>
						</thead>
						<tbody>

							{% for user in users %}

								<tr>

									<td>{{ loop.index }}</td>
									<td>{{ user.prenom|default('') }}
										{{ user.nom|default('') }}</td>
									<td>
										<div class="fw-semibold">
											{{ user.username }}
										</div>
									</td>
									<td>{{ user.application ? user.application.name|default('no defined') : 'no defined' }}</td>
									<td>
										{% if user.profile %}
											<span class="badge bg-primary text-white" style="font-size: 0.7rem; padding: 0.5rem 0.75rem;">
												<i class="bi bi-shield-lock me-1"></i>
												{{ user.profile.nom }}
											</span>
										{% else %}
											<span class="text-muted small">
												<i class="bi bi-dash-circle me-1"></i>
												Aucun profil</span>
										{% endif %}
									</td>
									<td>
										{% if user.profile %}
											{% set privileges = user.profile.privileges %}
											{% if privileges|length > 0 %}
												<div class="d-flex flex-wrap gap-1">
													{% for privilege in privileges %}
														<span class="badge bg-success text-white" style="font-size: 0.6rem; padding: 0.4rem 0.6rem;">
															<i class="bi bi-check-circle me-1"></i>
															{{ privilege.name }}
														</span>
													{% endfor %}
												</div>
											{% else %}
												<span class="text-muted small">
													<i class="bi bi-dash-circle me-1"></i>Aucun privilège</span>
											{% endif %}
										{% else %}
											<span class="text-muted small">—</span>
										{% endif %}
									</td>
									<td>
										<div class="d-flex justify-content-end">
											<div class="dropdown">
												<button type="button" class="btn p-0 dropdown-toggle" data-bs-toggle="dropdown">
													<i class="bx bx-dots-vertical-rounded"></i>
												</button>

												<div class="dropdown-menu">
													<a href="{{ path('app_user_show', {'id': user.id}) }}" class="dropdown-item">

														<i class="ti ti-eye me-1"></i>
														Voir

													</a>

													<a href="{{ path('app_user_edit', {'id': user.id}) }}" class="dropdown-item">

														<i class="ti ti-pencil me-1"></i>
														Modifier

													</a>
													<form id="delete-user-{{ user.id }}" method="post" action="{{ path('app_user_delete', {'id': user.id}) }}" class="d-none">
														<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
													</form>
													<a href="#" class="dropdown-item text-danger" onclick="event.preventDefault(); if (confirm('Voulez-vous vraiment supprimer cet utilisateur ?')) { document.getElementById('delete-user-{{ user.id }}').submit(); }">
														<i class="ti ti-trash me-1"></i>Supprimer
													</a>
												</div>
											</div>
										</div>
									</td>
								</tr>

							{% else %}

								<tr>
									<td colspan="4" class="text-center text-muted py-4">
										<i class="bi bi-people fs-3 d-block mb-2"></i>
										Aucun utilisateur trouvé.

									</td>

								</tr>

							{% endfor %}

						</tbody>

					</table>

				</div>

			</div>

		</div>

	</div>
{% endblock %}
