<ul class="menu list-unstyled">
	{% if items is empty %}
		<li class="p-2 text-center text-muted small">Aucun ticket récent</li>
	{% else %}
		{% for t in items %}
			<li>
				<a href="{{ path('app_ticket_chat_show', {id: t.id}) }}">
					<div class="icon-circle bg-blue">
						<i class="zmdi zmdi-assignment"></i>
					</div>
					<div class="menu-info">
						<h4>{{ t.title|length > 40 ? t.title|slice(0,40) ~ '…' : t.title }}</h4>
						<p>
							<i class="zmdi zmdi-account"></i>
							{{ t.marchand }}
							&nbsp;—&nbsp;
							<span class="text-muted">{{ t.replies }}
								message{{ t.replies > 1 ? 's' : '' }}</span>
							&nbsp;·&nbsp;<small class="text-muted">{{ t.timeAgo }}</small>
						</p>
					</div>
				</a>
			</li>
		{% endfor %}
	{% endif %}
</ul>
