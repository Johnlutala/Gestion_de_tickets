{{ form_start(form, {'attr': {'id': 'role-form', 'class': 'p-3 rounded shadow-sm bg-white'}}) }}

<div class="row">
	{# Nom du rôle #}
	<div class="col-md-6 mb-3">
		{{ form_label(form.nom, "Nom du rôle", {'label_attr': {'class': 'form-label fw-bold'}}) }}
		{{ form_widget(form.nom, {'attr': {'class': 'form-control', 'placeholder': 'Ex: ROLE_MANAGER'}}) }}
		{{ form_errors(form.nom) }}
	</div>

	{# Privilèges #}
	<div class="col-md-6 mb-3">
		{{ form_label(form.privileges, "Privilèges", {'label_attr': {'class': 'form-label fw-bold'}}) }}
		{{ form_widget(form.privileges, {'attr': {'class': 'form-control ms'}}) }}
		{{ form_errors(form.privileges) }}
	</div>
</div>

<hr class="my-4">

<div class="d-flex justify-content-between align-items-center">
	<a href="{{ path('app_role_index') }}" class="text-decoration-none text-secondary">
		<i class="bi bi-arrow-left"></i>
		Retour
	</a>
	<button type="submit" class="btn btn-primary px-5 shadow-sm">
		<i class="bi bi-check-circle me-2"></i>Enregistrer
	</button>
</div>

{{ form_end(form) }}
