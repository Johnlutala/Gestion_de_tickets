{{ form_start(form, {'attr': {'id': 'role-form', 'class': 'p-3 rounded shadow-sm bg-white'}}) }}

<div class="row">
	{# Nom du rôle #}
	<div class="col-md-6 mb-3">
		{{ form_label(form.nom, "Nom du rôle", {'label_attr': {'class': 'form-label fw-bold'}}) }}
		{{ form_widget(form.nom, {'attr': {'class': 'form-control', 'placeholder': 'Ex: ROLE_MANAGER'}}) }}
		{{ form_errors(form.nom) }}
	</div>

	{# Privilèges #}
	<div class="col-md-6 mb-3">
		<label class="form-label fw-bold">Privilèges</label>
		<div class="border rounded p-3" style="background-color: #f8f9fa;">
			{% for privilege in form.privileges %}
				<div class="form-check mb-2">
					{{ form_widget(privilege, {'attr': {'class': 'form-check-input'}}) }}
					<label class="form-check-label text-dark" for="{{ privilege.vars.id }}">
						{{ privilege.vars.label }}
					</label>
				</div>
			{% endfor %}
		</div>
		{{ form_errors(form.privileges) }}
	</div>
</div>

<hr class="my-4">

<div class="d-flex justify-content-between align-items-center">
	<a href="{{ path('app_role_index') }}" class="text-decoration-none text-secondary">
		<i class="bi bi-arrow-left"></i>
		Retour
	</a>
	<button type="submit" class="btn btn-primary px-5 shadow-sm">
		<i class="bi bi-check-circle me-2"></i>Enregistrer
	</button>
</div>

{{ form_end(form) }}
