{% extends 'base.html.twig' %}

{% block title %}Détails du rôle - {{ role.nom }}{% endblock %}

{% block body %}

	<div class="container py-4" style="margin-right: 20px;">

		<div class="card shadow-sm border-0 rounded-3">
			<div class="card-body py-4 px-4">
				<h5 class="fw-semibold mb-3 text-secondary">
					<i class="ti ti-shield-lock me-2 text-primary"></i>
					Détails du rôle
				</h5>

				<div class="row mb-4">
					<div class="col-md-6">
						<label class="form-label fw-bold text-muted">ID</label>
						<p class="fs-6">{{ role.id }}</p>
					</div>

					<div class="col-md-6">
						<label class="form-label fw-bold text-muted">Nom du rôle</label>
						<p class="fs-6">
							<span class="badge bg-info text-dark fs-6">{{ role.nom }}</span>
						</p>
					</div>
				</div>

				<hr>

				<h6 class="fw-bold mb-3">Privilèges assignés</h6>
				<div class="mb-4">
					{% if role.privileges|length > 0 %}
						<div class="d-flex flex-wrap gap-2">
							{% for privilege in role.privileges %}
								<span class="badge bg-success p-2">
									<i class="bi bi-check-circle me-1"></i>{{ privilege.name }}
									<small class="d-block">{{ privilege.description }}</small>
								</span>
							{% endfor %}
						</div>
					{% else %}
						<div class="alert alert-info">
							<i class="bi bi-info-circle me-2"></i>
							Aucun privilège n'est assigné à ce rôle.
						</div>
					{% endif %}
				</div>

				<div class="mt-4 pt-3 border-top">
					<a href="{{ path('app_role_index') }}" class="btn btn-secondary btn-sm">
						<i class="bi bi-arrow-left me-1"></i>Retour
					</a>
					<a href="{{ path('app_role_edit', {'id': role.id}) }}" class="btn btn-primary btn-sm">
						<i class="bi bi-pencil me-1"></i>Modifier
					</a>
					<form method="post" action="{{ path('app_role_delete', {'id': role.id}) }}" onsubmit="return confirm('Voulez-vous vraiment supprimer ce rôle ?');" class="d-inline">
						<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ role.id) }}">
						<button type="submit" class="btn btn-danger btn-sm">
							<i class="bi bi-trash me-1"></i>Supprimer
						</button>
					</form>
				</div>
			</div>
		</div>

	</div>

{% endblock %}
