{% extends 'base.html.twig' %}

{% block title %}Liste des rôles{% endblock %}

{% block body %}

	<div class="container">

		<div class="card mb-4">

			<div class="card-body">

				<div class="d-flex justify-content-between align-items-center mb-3">

					<div>
						<h4 class="fw-bold mb-0">
							<i class="bi bi-shield-lock text-primary me-2"></i>
							Liste des rôles
						</h4>
						<small class="text-muted">Gestion des rôles et leurs privilèges</small>
					</div>

					<a href="{{ path('app_role_new') }}" class="btn btn-primary btn-sm">
						<i class="bi bi-plus-circle me-1"></i>
						Nouveau rôle
					</a>

				</div>

				<div class="table-responsive">
					<table class="table table-hover align-middle">

						<thead class="table-light">
							<tr>
								<th>#</th>
								<th>Nom du rôle</th>
								<th>Privilèges</th>
								<th class="text-end">Actions</th>
							</tr>
						</thead>

						<tbody>
							{% for role in roles %}
								<tr>
									<td>{{ loop.index }}</td>
									<td>
										<div class="fw-semibold">{{ role.nom }}</div>
									</td>
									<td>
										{% if role.privileges|length > 0 %}
											<div class="d-flex flex-wrap gap-1">
												{% for privilege in role.privileges %}
													<span class="badge bg-success text-white" style="font-size: 0.8rem; padding: 0.4rem 0.6rem;">
														<i class="bi bi-check-circle me-1"></i>{{ privilege.name }}
													</span>
												{% endfor %}
											</div>
										{% else %}
											<span class="text-muted small"><i class="bi bi-dash-circle me-1"></i>Aucun privilège assigné</span>
										{% endif %}
									</td>
									<td>
										<div class="d-flex justify-content-end">
											<div class="dropdown">
												<button type="button" class="btn p-0 dropdown-toggle" data-toggle="dropdown">
													<i class="bx bx-dots-vertical-rounded"></i>
												</button>
												<div class="dropdown-menu">
													<a href="{{ path('app_role_show', {'id': role.id}) }}" class="dropdown-item">
														<i class="ti ti-eye me-1"></i>Voir
													</a>
													<a href="{{ path('app_role_edit', {'id': role.id}) }}" class="dropdown-item">
														<i class="ti ti-pencil me-1"></i>Modifier
													</a>
													<form method="post" action="{{ path('app_role_delete', {'id': role.id}) }}" onsubmit="return confirm('Voulez-vous vraiment supprimer ce rôle ?');">
														<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ role.id) }}">
														<button type="submit" class="dropdown-item text-danger">
															<i class="ti ti-trash me-1"></i>Supprimer
														</button>
													</form>
												</div>
											</div>
										</div>
									</td>
								</tr>
							{% else %}
								<tr>
									<td colspan="4" class="text-center text-muted py-4">
										<i class="bi bi-shield-lock text-muted fs-3 d-block mb-2"></i>
										Aucun rôle trouvé.
									</td>
								</tr>
							{% endfor %}
						</tbody>

					</table>

				</div>

			</div>

		</div>

	</div>

{% endblock %}
