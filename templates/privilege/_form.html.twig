{{ form_start(form, {'attr': {'class': 'p-4 rounded shadow-sm bg-white'}}) }}

<div
	class="row">
	
	<div class="col-md-6 mb-3">
		{{ form_label(form.name, "Nom d'utilisateur", {'label_attr': {'class': 'form-label fw-bold'}}) }}
		{{ form_widget(form.name, {'attr': {'class': 'form-control', 'placeholder': 'Ex: admin@gmail.com'}}) }}
		{{ form_errors(form.name) }}
	</div>

	<div class="col-md-6 mb-3">
		{{ form_label(form.description, "Nom d'utilisateur", {'label_attr': {'class': 'form-label fw-bold'}}) }}
		{{ form_widget(form.description, {'attr': {'class': 'form-control', 'placeholder': 'Ex: Un Administrateur possede tous les roles dans les roles ' }}) }}
		{{ form_errors(form.description) }}
	</div>

	<div class="col-md-6 mb-3">
			{{ form_label(form.roles, 'Profil / Rôle', {'label_attr': {'class': 'form-label fw-bold'}}) }}
			{{ form_widget(form.roles, {'attr': {'class': 'form-control ms'}}) }}
			{{ form_errors(form.roles) }}

	</div>
</div>



<hr class="my-4">

<div class="d-flex justify-content-between align-items-center">
	<a href="#" class="text-decoration-none text-secondary">
		<i class="bi bi-arrow-left"></i>
		Retour
	</a>
	<button type="submit" class="btn btn-primary px-5 shadow-sm">
		<i class="bi bi-check-circle me-2"></i>Enregistrer
	</button>
</div>

    <button class="btn">{{ button_label|default('Save') }}</button>
{{ form_end(form) }}
