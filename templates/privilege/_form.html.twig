{{ form_start(form, {'attr': {'id': 'privilege-form', 'class': 'p-3 rounded shadow-sm bg-white'}}) }}

<div class="row">
	{# Nom du privilège #}
	<div class="col-md-6 mb-3">
		{{ form_label(form.name, "Nom du privilège", {'label_attr': {'class': 'form-label fw-bold'}}) }}
		{{ form_widget(form.name, {'attr': {'class': 'form-control', 'placeholder': 'Ex: CREATE_TICKET'}}) }}
		{{ form_errors(form.name) }}
	</div>

	{# Description #}
	<div class="col-md-6 mb-3">
		{{ form_label(form.description, "Description", {'label_attr': {'class': 'form-label fw-bold'}}) }}
		{{ form_widget(form.description, {'attr': {'class': 'form-control', 'placeholder': 'Ex: Permet de créer des tickets'}}) }}
		{{ form_errors(form.description) }}
	</div>
</div>

<hr class="my-4">

<p class="text-muted small">
	<i class="bi bi-info-circle me-1"></i>
	Pour associer ce privilège à des rôles, allez dans la gestion des rôles.
</p>

<div class="d-flex justify-content-between align-items-center">
	<a href="{{ path('app_privilege_index') }}" class="text-decoration-none text-secondary">
		<i class="bi bi-arrow-left"></i>
		Retour
	</a>
	<button type="submit" class="btn btn-primary px-5 shadow-sm">
		<i class="bi bi-check-circle me-2"></i>Enregistrer
	</button>
</div>

{{ form_end(form) }}
